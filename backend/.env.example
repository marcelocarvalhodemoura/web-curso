# =============================================================================
# DevTrail — template de variáveis de ambiente
# Copie para .env:  cp .env.example .env
# =============================================================================

# --- Turso (banco na nuvem) ---
# turso db show devtrail --url
# turso db tokens create devtrail
# Deixe em branco para usar SQLite local em data/curso.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- Autenticação (JWT) ---
JWT_SECRET=

# --- Usuário admin inicial (criado pelo seed) ---
ADMIN_EMAIL=admin@devtrail.com
ADMIN_PASSWORD=admin123

# --- Banco local (opcional) ---
# DATA_DIR=../../data
